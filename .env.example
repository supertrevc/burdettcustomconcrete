# Copy to .env.local and fill in. Never commit real secrets.

# Public site origin (used for canonical URLs, sitemap, OG image URLs).
# No trailing slash. Update to the real production domain before launch.
NEXT_PUBLIC_SITE_URL=https://burdettcustomconcrete.com

# Resend API key for the free-quote notification email (server-side only).
# Get one at https://resend.com. If unset, the quote form still works but
# the API route logs the submission instead of emailing.
RESEND_API_KEY=

# Where quote notifications are sent. Defaults to dbrd0303@gmail.com if unset.
QUOTE_NOTIFY_EMAIL=dbrd0303@gmail.com

# Verified "from" address/domain in Resend. Until a domain is verified you can
# use onboarding@resend.dev for testing.
QUOTE_FROM_EMAIL=onboarding@resend.dev
